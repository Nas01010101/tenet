# ---- Secrets: NEVER commit ----
.env
.env.*
!.env.example
secrets/
*.key
*.pem
*.p12
credentials.json
client_secret*.json
token.json
*.credentials
# ---- Python ----
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
*.egg-info/
# ---- Node ----
node_modules/
# ---- OS / editor ----
.DS_Store
.idea/
.vscode/
# ---- Build / artifacts ----
dist/
build/
*.log
recordings/
# ---- Local data (memory store) ----
# `data` (no trailing slash) also matches the entry itself when it's a
# symlink — `data/` alone doesn't (git only matches symlinks-as-directories
# with the slash form in some versions), and a symlink accidentally
# `git add -f`'d here is exactly B1 (see memory.py's _resolve_default_db_path
# docstring): it breaks every fresh clone on a machine without that target.
data
data/
*.db

# ---- LaTeX build artifacts ----
paper/*.aux
paper/*.log
paper/*.out
paper/*.toc
paper/*.fls
paper/*.fdb_latexmk
data/cache/
scratchpad/
