# =============================================================================
#  qwen-hackathon — secrets template.  Copy to `.env` and fill in.
#  `.env` is gitignored + chmod 600.  NEVER commit real values.
#    cp .env.example .env && chmod 600 .env
# =============================================================================

# ---- Qwen Cloud / DashScope (the model API — OpenAI-compatible) -------------
# Get from: https://www.qwencloud.com  (Get an API Key)
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Singapore/intl base URL for OpenAI-compatible endpoint
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Responses/Conversations API (built-in tools, auto multi-turn) uses a different URL:
QWEN_RESPONSES_URL=https://dashscope-intl.aliyuncs.com/api/v2/apps/protocols/compatible-mode/v1
QWEN_MODEL=qwen3.7-plus

# ---- Provider selection (SHIPPED product uses Qwen Cloud; leave as-is) -------
# For off-Qwen validation only (e.g. Qwen quota exhausted):
#   LLM_PROVIDER=openrouter  EMBED_PROVIDER=local
LLM_PROVIDER=qwen           # qwen | openrouter | agy
EMBED_PROVIDER=qwen         # qwen | local (sentence-transformers)
# OpenRouter (chat fallback; no embeddings there — pair with EMBED_PROVIDER=local)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct
LOCAL_EMBED_MODEL=BAAI/bge-small-en-v1.5

# ---- Alibaba Cloud account (for the REQUIRED backend deployment proof) ------
# Get from: AliCloud console > RAM user AccessKey management.  Scope to least privilege
# (ECS/FC + OSS).  Do NOT use the root AccessKey.
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
ALIBABA_CLOUD_REGION=ap-southeast-1
# OSS (durable memory snapshots — the "uses Alibaba Cloud services/APIs" proof file)
OSS_ENDPOINT=https://oss-ap-southeast-1.aliyuncs.com
OSS_BUCKET=

# ---- GitHub (public repo + LICENSE is a submission requirement) -------------
# Fine-grained PAT, repo scope only.  Or leave blank and use `gh`/MCP.
GITHUB_TOKEN=

# ---- YouTube (3-min demo video upload — optional, needs OAuth) --------------
# Only if you want automated upload; otherwise upload by hand.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
